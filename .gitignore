.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# Virtualenv
.venv/
venv/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Agent-local artifacts
.claude/projects/
.claude/worktrees/
.codex/sessions/

# Logs
*.log

# Local config that should not flow
.playbook-config.yaml
.playbook-lock.json

# Human-in-loop review artifacts (always per-workspace, never committed)
docs/human-html/

# Brainstorming spec drafts (kept local until promoted to an ADR or merged feature)
docs/superpowers/

# Plugin / marketplace artifacts that the upstream sync may emit into the
# portfolio destination. These are operator-owned outputs, not public
# content; the portfolio repo keeps them untracked so an upstream
# configuration carrying internal catalog names cannot leak them into
# the public commit history.
plugins/
.claude-plugin/
.cursor-plugin/
.agents/plugins/
gemini-extension.json

